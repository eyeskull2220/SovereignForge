# SovereignForge Production Environment Configuration - Wave 6
# Copy this file to .env and update with your actual values

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Environment (development, staging, production)
ENVIRONMENT=production

# Application settings
APP_NAME=SovereignForge
APP_VERSION=6.0.0
LOG_LEVEL=INFO

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# PostgreSQL Database
DATABASE_URL=postgresql://sovereignforge:sovereignforge_pass@postgres:5432/sovereignforge

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ===========================================
# CACHE CONFIGURATION
# ===========================================

# Redis Cache
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=sovereignforge_cache

# Cache settings
CACHE_TTL=3600
CACHE_MAX_MEMORY=512mb

# ===========================================
# MONITORING & METRICS
# ===========================================

# Prometheus metrics
PROMETHEUS_MULTIPROC_DIR=/tmp
METRICS_ENABLED=true
METRICS_PORT=8000

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ===========================================
# TRADING CONFIGURATION
# ===========================================

# Trading symbols (comma-separated)
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,XRP/USDT,XLM/USDT,HBAR/USDT,ALGO/USDT,ADA/USDT

# Exchanges to use (comma-separated)
EXCHANGES=binance,coinbase,kraken

# Risk management
DAILY_LOSS_LIMIT=1000.00
MAX_POSITION_SIZE_PCT=0.01
DRAW_DOWN_LIMIT=0.10

# Arbitrage settings
MIN_ARBITRAGE_SPREAD=0.001
CONFIDENCE_THRESHOLD=0.7

# ===========================================
# EXCHANGE API KEYS
# ===========================================

# Binance API (encrypted in production)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Coinbase API
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kraken API
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ===========================================
# ALERTING CONFIGURATION
# ===========================================

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#sovereignforge-alerts

# Email notifications (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=

# ===========================================
# SECURITY SETTINGS
# ===========================================

# API security
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT=1000/hour

# Encryption keys (generate new ones for production)
ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# ===========================================
# PERFORMANCE SETTINGS
# ===========================================

# Async processing
MAX_WORKERS=4
QUEUE_SIZE=1000

# API timeouts
REQUEST_TIMEOUT=30
CONNECTION_TIMEOUT=10

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Log settings
LOG_TO_FILE=true
LOG_FILE_PATH=/app/logs/sovereignforge.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Structured logging
STRUCTLOG_ENABLED=true
LOG_FORMAT=json

# ===========================================
# BACKUP & RECOVERY
# ===========================================

# Database backup
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
DB_BACKUP_RETENTION_DAYS=30

# Model backup
MODEL_BACKUP_ENABLED=true
MODEL_BACKUP_PATH=/app/models/backups

# ===========================================
# DEVELOPMENT SETTINGS (ignore in production)
# ===========================================

# Debug mode (set to false in production)
DEBUG=false

# Jupyter notebook (development only)
JUPYTER_ENABLED=false
JUPYTER_PORT=8888
JUPYTER_TOKEN=sovereignforge-dev

# ===========================================
# CONTAINER SETTINGS
# ===========================================

# Docker container limits
CONTAINER_CPU_LIMIT=2.0
CONTAINER_MEMORY_LIMIT=4G

# Health check settings
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3