# SovereignForge .gitignore
# Exclude sensitive data, logs, and large model files

# Database files
*.db
*.sqlite
*.sqlite3
data/trading.db

# Log files
*.log
logs/
tensorboard/

# Model checkpoints (large files - exclude from repo)
models/*.pth
models/*.pt
models/final_*.pth
models/best_*.pth
models/checkpoints/
models/training_results/
models/secure/
models/strategies/dca_*.pth
models/strategies/fib_*.pth
models/strategies/grid_*.pth

# Warm start state (large runtime artifact)
warm_start_state.json

# Secrets and API keys
config/api_keys.json
config/secrets*

# Environment files
.env
.env.local
.env.*.local

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE files
# .vscode/  # Uncommented for workspace settings
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# Jupyter notebooks (if any)
.ipynb_checkpoints/

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Documentation build
docs/_build/

# Node modules (if any frontend components)
node_modules/

# Paper trading state
reports/paper_trading_state.json

# Runtime files
.paper_trading.pid
.launcher_pids.json
mlruns/

# MCP config (local)
.mcp.json
.mcp-servers/

# Docker volumes
volumes/